Algoritmo promedio
	
	Definir NumeroEntrada1, NumeroEntrada2, NumeroEntrada3,prom, totalsum Como Real
	Escribir "Ingrese 3 cantidades para sacar un promedio"
	
	Escribir "primer cantidad: "
	leer NumeroEntrada1
	
	Escribir "segunda cantidad: "
	leer NumeroEntrada2
	
	Escribir  "tercera cantidad :"
	Leer NumeroEntrada3
	
	totalsum = NumeroEntrada1+NumeroEntrada2+NumeroEntrada3 
	
	prom = totalsum / 3
	Escribir "El promedio es :", prom
	
	
	
	
	
	
FinAlgoritmo
