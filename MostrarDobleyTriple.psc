Algoritmo MostrarDobleyTriple
	Definir NumeroEntrada1,doble,triple Como Real
	Escribir "Ingrese 1 cantidad"
	leer NumeroEntrada1
	
	

	
	doble = NumeroEntrada1 * 2
	triple = NumeroEntrada1 * 3
	
	Escribir "El doble de el numero :", NumeroEntrada1, " es ",doble, " y su triple es ",triple
	
FinAlgoritmo
